# Turso database connection (required)
# Two databases exist — local dev and PR previews use staging, production uses prod:
#   Production: libsql://quiet-riots-skye-quiet-riots.aws-eu-west-1.turso.io
#   Staging:    libsql://quiet-riots-staging-skye-quiet-riots.aws-eu-west-1.turso.io
#
# IMPORTANT: Your .env.local should point to STAGING for day-to-day development.
# DO NOT point .env.local at production — npm run seed will drop all tables.
# To run scripts against production, pass env vars explicitly on the command line.
TURSO_DATABASE_URL=libsql://quiet-riots-staging-skye-quiet-riots.aws-eu-west-1.turso.io
TURSO_AUTH_TOKEN=your-turso-staging-auth-token

# Bot API authentication (optional for web-only dev, required for WhatsApp bot)
# This key protects the /api/bot endpoint. The WhatsApp bot (OpenClaw) sends this
# as a Bearer token. Use any string for local dev — production key is in Vercel env vars.
BOT_API_KEY=qr-bot-dev-key-2026

# Auth.js v5 (required in production — optional for local dev)
# AUTH_SECRET is used to sign JWTs and encrypt cookies. Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-at-least-32-chars
# OAuth providers (optional — auth falls back to email magic link if not set)
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
# AUTH_FACEBOOK_ID=your-facebook-app-id
# AUTH_FACEBOOK_SECRET=your-facebook-app-secret

# Resend email (optional — required for email magic link auth)
# Create a free account at https://resend.com, add your domain, and get an API key.
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=noreply@quietriots.com

# Vercel Blob storage (optional — required for evidence media uploads)
# Auto-created when you add a Blob store in Vercel Dashboard (Settings > Storage > Blob).
# For local dev: run `npx vercel env pull` from the main repo root to populate .env.local.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# Sentry error monitoring (optional — errors only reported in production)
# Create a free account at https://sentry.io, create a Next.js project,
# and copy the DSN from Settings > Client Keys.
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@o123.ingest.sentry.io/456
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=quiet-riots
# SENTRY_AUTH_TOKEN=sntrys_your-auth-token

# PostHog analytics (optional — events only sent when key is configured)
# Create a free account at https://posthog.com, create a project,
# and copy the Project API Key from Settings > Project > API Key.
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-api-key
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Node environment (set automatically by Next.js, shown here for reference)
# NODE_ENV=development
